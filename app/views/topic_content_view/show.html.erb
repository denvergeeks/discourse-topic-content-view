<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title><%= @title %></title>
  <style>
    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
    body {
      font-family: -apple-system, BlinkMacSystemFont, "Segoe UI", Roboto, sans-serif;
      font-size: 16px;
      line-height: 1.6;
      color: #222;
      background: #fff;
      padding: 1.5rem;
    }
    .tc-title {
      font-size: 1.6rem;
      font-weight: 700;
      margin-bottom: 1rem;
      line-height: 1.3;
    }
    .tc-body img { max-width: 100%; height: auto; }
    .tc-body a { color: #1155cc; }
    .tc-body p { margin-bottom: 1em; }
    .tc-body h1,.tc-body h2,.tc-body h3,.tc-body h4 {
      font-weight: 700; margin: 1.2em 0 0.4em;
    }
    .tc-body pre {
      background: #f5f5f5; padding: 1em; overflow-x: auto;
      border-radius: 4px; margin-bottom: 1em;
    }
    .tc-body code {
      background: #f5f5f5; padding: 0.1em 0.3em; border-radius: 3px;
      font-size: 0.9em;
    }
    .tc-body blockquote {
      border-left: 3px solid #ccc; padding-left: 1em;
      color: #555; margin-bottom: 1em;
    }
    .tc-body ul, .tc-body ol { padding-left: 1.5em; margin-bottom: 1em; }
  </style>
</head>
<body>
  <h1 class="tc-title"><%= @title %></h1>
  <div class="tc-body">
    <%= raw @cooked %>
  </div>
</body>
</html>
